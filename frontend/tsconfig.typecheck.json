{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false
  },
  "include": [
    "src/services",
    "src/contexts",
    "src/lib",
    "src/types",
    "src/utils"
  ],
  "exclude": [
    "node_modules",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "dist",
    "build"
  ]
}
